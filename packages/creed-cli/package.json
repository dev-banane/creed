{
  "name": "creed-cli",
  "version": "0.2.2",
  "description": "The first-party terminal client for Creed.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "creed": "dist/src/bin.js",
    "creed-cli": "dist/src/bin.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Connor Hepburn",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm test",
    "test": "npm run build && node --test 'dist/tests/**/*.test.js'",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "creed",
    "mcp",
    "cli",
    "context",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/connorhpbrn/creed.git",
    "directory": "packages/creed-cli"
  },
  "homepage": "https://creed.md",
  "bugs": "https://github.com/connorhpbrn/creed/issues"
}
